# Caminho de deploy na VPS
DEPLOY_PATH=/opt/infra-swarm

# Domínios
DOMAIN_HERICAREALTOR=your-app.com
DOMAIN_TYERSHOP=your-domain.dev
DOMAIN_JUSTGUI=your-domain.dev

# URLs derivadas (ajuste conforme os domínios acima)
URL_HERICAREALTOR=https://your-app.com
# Loja Astro (homolog ou produção) — usado pelo frontend e CORS da API Node
URL_TYERSHOP=https://homolog.tyershop.com
URL_JUSTGUI=https://your-domain.dev
URL_N8N=https://n8n.your-domain.dev
URL_MINIO=https://minio.your-domain.dev
URL_MINIO_CONSOLE=https://minio-console.your-domain.dev
URL_SUPPORT=https://support.justgui.dev
URL_SUPPORT_TYERSHOP=https://suporte.your-domain.dev
URL_EVOLUTION=https://evolution.your-domain.dev
URL_PORTAINER=https://portainer.your-domain.dev

# Certbot
CERTBOT_EMAIL=admin@your-domain.dev

# MinIO
MINIO_ROOT_USER=changeme_user
MINIO_ROOT_PASSWORD=changeme_strong_password
# URL pública da consola MinIO (redirect do browser; alinhar com URL_MINIO_CONSOLE)
MINIO_BROWSER_REDIRECT_URL=https://minio-console.your-domain.dev

# n8n
N8N_BASIC_AUTH_USER=changeme_user
N8N_BASIC_AUTH_PASSWORD=changeme_strong_password
N8N_ENCRYPTION_KEY=changeme_32char_random_key_here_

# SMTP Settings (hericarealtor mail, n8n, base para Chatwoot)
SMTP_HOST=smtp.provider.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@your-domain.dev
SMTP_PASSWORD=changeme

# Chatwoot (stack comms) — instâncias separadas; podes repetir SMTP_USER/PASSWORD se for o mesmo servidor
SMTP_JUSTGUI_USER=no-reply@your-domain.dev
SMTP_JUSTGUI_PASSWORD=changeme
SMTP_TYERSHOP_USER=no-reply@tyershop.com
SMTP_TYERSHOP_PASSWORD=changeme

# Chatwoot + Evolution (stack comms — PostgreSQL compartilhado)
COMMS_POSTGRES_USER=comms
COMMS_POSTGRES_PASSWORD=changeme_strong_password
CHATWOOT_SECRET_KEY_BASE=changeme_64char_random_key
CHATWOOT_TYERSHOP_SECRET_KEY_BASE=changeme_64char_random_key_tyershop

# Evolution API
EVOLUTION_API_KEY=changeme_strong_api_key
EVOLUTION_REDIS_PREFIX=evolution

# hericarealtor (Laravel + Octane)
HERICAREALTOR_TAG=latest
# APP_KEY gerado com: php artisan key:generate --show
HERICAREALTOR_APP_KEY=base64:changeme=
HERICAREALTOR_DB_USER=hericarealtor
HERICAREALTOR_DB_NAME=hericarealtor
HERICAREALTOR_DB_PASSWORD=changeme_strong_password
GOOGLE_MAPS_API_KEY=changeme_google_maps_key

# justgui (API + web Astro)
JUSTGUI_TAG=latest

# tyershop (Medusa + Astro + API)
TYERSHOP_BACKEND_TAG=latest
TYERSHOP_FRONTEND_TAG=latest
TYERSHOP_API_TAG=latest
TYERSHOP_DB_USER=tyershop
TYERSHOP_DB_NAME=tyershop
TYERSHOP_DB_PASSWORD=changeme_strong_password
# Redis (stack Swarm lê isto via scripts/tyershop-sync-secrets.sh → secret tyershop_redis_password)
TYERSHOP_REDIS_PASSWORD=changeme_redis_strong_password
TYERSHOP_JWT_SECRET=changeme_random_32chars_minimum
TYERSHOP_COOKIE_SECRET=changeme_random_32chars_minimum
# S3/MinIO secret key no Medusa (opcional: se vazio, o sync usa MINIO_ROOT_PASSWORD)
TYERSHOP_AWS_SECRET_ACCESS_KEY=
TYERSHOP_S3_BUCKET=tyershop
TYERSHOP_PUBLIC_PUBLISHABLE_KEY=replace_with_publishable_key
# CORS Medusa (origens HTTPS separadas por vírgula). Incluir admin + storefront.
TYERSHOP_STORE_CORS=https://homolog.tyershop.com,https://www.homolog.tyershop.com
TYERSHOP_ADMIN_CORS=https://admin.tyershop.com,https://homolog.tyershop.com
TYERSHOP_AUTH_CORS=https://homolog.tyershop.com,https://www.homolog.tyershop.com
TYERSHOP_NEWSLETTER_FROM=news@tyershop.com
TYERSHOP_NEWSLETTER_TO=
# API checkout — valor vai para o secret tyershop_mercadopago_access_token (sync script)
MERCADOPAGO_ACCESS_TOKEN=

# Após editar passwords acima, na VPS: bash scripts/tyershop-sync-secrets.sh
# (cria secrets Swarm a partir deste .env; ver cabeçalho do script para rotação)

# Zillow scraper (listings-updater)
ZILLOW_ENCODED_ZUID=changeme
ZILLOW_PROFILE_SLUG=changeme
HERICAREALTOR_INTERNAL_TOKEN=generate_random_32chars
N8N_WEBHOOK_LISTINGS_RESULT=https://n8n.justgui.dev/webhook/listings-result
N8N_WEBHOOK_WWP_RESULT=https://n8n.justgui.dev/webhook/wwp-result

# Certificados SSL: o script scripts/certbot-init.sh tem a lista DOMAINS em código —
# edita esse array para coincidir com os teus domínios (e com o DNS na VPS) antes de correr o certbot.
